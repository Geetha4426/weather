# ═══════════════════════════════════════════════════════════════
# Weather Prediction Bot — Polymarket Weather Markets
# Deploy on Railway (EU/Netherlands — no proxy needed)
# ═══════════════════════════════════════════════════════════════

# ─── REQUIRED: Telegram ───
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── REQUIRED: Polymarket Wallet ───
POLY_PRIVATE_KEY=your_private_key_here
POLY_PROXY_WALLET=your_proxy_wallet_if_using_safe
POLY_FUNDER_ADDRESS=
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=
# Signature type: 0 = EOA wallet, 2 = Polymarket proxy/safe
POLY_SIGNATURE_TYPE=0
POLY_CHAIN_ID=137

# ─── Trading Mode ───
# Start with 'paper' to test, switch to 'live' when confident
TRADING_MODE=paper
STARTING_BALANCE=100.0
USE_FOK_ORDERS=true

# ─── Proxy (NOT required for EU deployment) ───
# Only set if you are in a geoblocked country
# PROXY_URL=socks5://user:pass@host:port

# ─── Weather Cities ───
# Polymarket slug names: nyc, london, chicago, miami, seattle, atlanta, dallas, munich, lucknow
WEATHER_CITIES=nyc,london,chicago,miami,seattle,atlanta,dallas,munich,lucknow

# ─── Scan & Thresholds (tuned from real profitable bots) ───
WEATHER_SCAN_INTERVAL=120
WEATHER_MIN_EDGE=0.15
WEATHER_EXIT_EDGE=0.45
WEATHER_MAX_POSITION_USD=2.0
WEATHER_MAX_TRADES_PER_RUN=5
WEATHER_MAX_POSITIONS_PER_EVENT=3
WEATHER_MAX_TOTAL_POSITIONS=15
WEATHER_LOOKAHEAD_DAYS=3
RISK_MODE=conservative

# ─── Confidence ───
WEATHER_MIN_CONFIDENCE=0.40
WEATHER_HIGH_CONFIDENCE=0.75
WEATHER_TREND_DETECTION=true

# ─── Weather APIs (Optional — Open-Meteo is FREE and always used) ───
# Tomorrow.io: free tier = 500 calls/day. Get key at https://app.tomorrow.io
TOMORROW_IO_API_KEY=
# WeatherAPI: free tier = 1M calls/month. Get key at https://weatherapi.com
WEATHERAPI_KEY=
# OpenWeatherMap: free tier = 1000 calls/day. Get key at https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ─── Risk ───
MAX_DAILY_LOSS_PCT=20.0

# ─── Database ───
DATABASE_PATH=data/weather_trades.db
